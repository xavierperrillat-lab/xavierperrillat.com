<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Xavier Perrillat — Studio de création</title>
<style>
/* ===========================================
   FONT
   =========================================== */
@font-face {
  font-family: 'Grotta';
  src: url('/assets/fonts/Grotta-Medium.woff2') format('woff2'),
       url('/assets/fonts/Grotta-Medium.woff') format('woff');
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}

/* ===========================================
   RESET
   =========================================== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; font-weight: 500; }
h1, h2, h3, h4, h5, h6, strong, b, th, button { font-weight: 500; }

html {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  scroll-padding-top: 80px;
}

body {
  font-family: 'Grotta', sans-serif;
  font-weight: 500;
  color: #000;
  background: #fff;
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }
img { max-width: 100%; display: block; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* ===========================================
   HEADER
   =========================================== */
.header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: #fff;
}

.header__inner {
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #000;
}

.header__logo {
  font-family: 'Grotta', sans-serif;
  font-size: 32px;
  color: #000;
  cursor: pointer;
  line-height: 1;
}

.header__right {
  display: flex;
  align-items: center;
  gap: 36px;
}

.header__lang {
  display: flex;
  align-items: center;
  gap: 2px;
  line-height: 1;
}

.header__lang-btn {
  background: none;
  border: none;
  font-family: 'Grotta', sans-serif;
  font-size: 32px;
  color: #000;
  cursor: pointer;
  padding: 0 2px;
  line-height: 1;
  position: relative;
}

.header__lang-btn::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 100%;
  height: 1px;
  background: #000;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

@media (hover: hover) { .header__lang-btn:hover::after { transform: scaleX(1); } }
.header__lang-sep { font-size: 32px; color: #000; line-height: 1; }

.header__burger {
  cursor: pointer;
  width: 30px;
  height: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.header__burger-line {
  display: block;
  width: 30px;
  height: 3px;
  background: #000;
  transform-origin: center center;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Stagger shiver on hover */
@keyframes shiverTop {
  0% { transform: translateX(0); }
  20% { transform: translateX(6px); }
  50% { transform: translateX(-3px); }
  70% { transform: translateX(2px); }
  100% { transform: translateX(0); }
}

@keyframes shiverBottom {
  0% { transform: translateX(0); }
  25% { transform: translateX(-5px); }
  55% { transform: translateX(4px); }
  75% { transform: translateX(-2px); }
  100% { transform: translateX(0); }
}

@media (hover: hover) {
  .header__burger:hover .header__burger-line:first-child {
    animation: shiverTop 0.4s ease;
  }

  .header__burger:hover .header__burger-line:last-child {
    animation: shiverBottom 0.4s ease 0.05s;
  }
}

/* Cross state overrides hover */
.header__burger.is-cross .header__burger-line:first-child {
  transform: translateY(4.5px) rotate(45deg);
}

.header__burger.is-cross .header__burger-line:last-child {
  transform: translateY(-4.5px) rotate(-45deg);
}

/* ===========================================
   MENU
   =========================================== */
.menu {
  position: sticky;
  top: 80px;
  z-index: 999;
  background: #fff;
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.menu.is-open { max-height: 320px; }

.menu__item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 160px;
  border-bottom: 1px solid #000;
  cursor: pointer;
}

.menu__item-text {
  font-family: 'Grotta', sans-serif;
  font-size: 32px;
  color: #000;
  position: relative;
  display: inline-block;
  line-height: 1;
}

.menu__item-text::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  width: 100%;
  height: 1px;
  background: #000;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

@media (hover: hover) { .menu__item:hover .menu__item-text::after { transform: scaleX(1); } }

/* ===========================================
   HERO
   =========================================== */
.hero {
  position: relative;
  padding-top: 75px;
  padding-bottom: 0;
  overflow: hidden;
}

.hero__text { margin-bottom: 0; position: relative; z-index: 2; }

.hero__line {
  display: block;
  overflow: hidden;
  position: relative;
  font-family: 'Grotta', sans-serif;
  font-size: clamp(32px, 7vw, 96px);
  line-height: 1.15;
  color: #000;
  height: 1.2em;
  white-space: nowrap;
}

.hero__line--animated .hero__slide-track {
  position: relative;
  height: 100%;
  width: 100%;
}

.hero__line--animated .hero__slide-item {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  will-change: transform;
  white-space: nowrap;
}

.hero__slide-item.is-visible { transform: translateY(0%); }
.hero__slide-item.is-below { transform: translateY(115%); }
.hero__slide-item.sliding {
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Showreel placeholder — hidden, managed via CMS */
.hero__placeholder {
  display: none;
  width: 100%;
  aspect-ratio: 1920 / 1080;
  background: #d9d9d9;
  position: relative;
}

.hero__placeholder-label {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 14px;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 2px;
}

/* ===========================================
   PROJETS
   =========================================== */
.projets {
  padding-top: 267px;
  padding-bottom: 80px;
}

.projets__title {
  font-family: 'Grotta', sans-serif;
  font-size: clamp(18px, 2.8vw, 36px);
  color: #000;
  padding-bottom: 20px;
  margin-bottom: 0;
}

.projet-item { border-top: 1px solid #000; }
.projet-item:last-child { border-bottom: 1px solid #000; }

.projet-item__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: clamp(70px, 12vw, 160px);
  cursor: pointer;
  position: relative;
}

.projet-item__name {
  font-family: 'Grotta', sans-serif;
  font-size: clamp(28px, 5.5vw, 96px);
  line-height: 1;
  color: #000;
  transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
  position: relative;
  z-index: 1;
}

@media (hover: hover) {
  .projet-item:not(.is-open) .projet-item__header:hover .projet-item__name {
    transform: translateX(30px);
  }
}

.projet-item__close {
  display: none;
  width: 30px;
  height: 30px;
  cursor: pointer;
  background: none;
  border: none;
  position: relative;
  z-index: 3;
  flex-shrink: 0;
}

.projet-item__close::before,
.projet-item__close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 30px;
  height: 3px;
  background: #000;
}

.projet-item__close::before { transform: translate(-50%, -50%) rotate(45deg); }
.projet-item__close::after { transform: translate(-50%, -50%) rotate(-45deg); }
@media (hover: hover) { .projet-item__close:hover { transform: rotate(360deg); transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1); } }

.projet-item.is-open .projet-item__close { display: block; }

.projet-item__miniature {
  position: absolute;
  width: clamp(70px, 12vw, 160px);
  height: clamp(70px, 12vw, 160px);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.25s ease;
  z-index: 2;
  top: 0;
  overflow: hidden;
}

.projet-item__miniature img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

@media (hover: hover) {
  .projet-item:not(.is-open) .projet-item__header:hover .projet-item__miniature {
    opacity: 1;
  }
}

.projet-item__fiche {
  overflow: hidden;
  height: 0;
}

.projet-item__fiche-inner {
  padding: 40px 0 80px;
  opacity: 0;
  transition: opacity 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.projet-item.is-open .projet-item__fiche-inner {
  opacity: 1;
}

.projet-item__description {
  font-family: 'Grotta', sans-serif;
  font-size: clamp(18px, 2.8vw, 36px);
  line-height: 1.3;
  color: #000;
  margin-bottom: 60px;
}

.projet-item__galerie {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.projet-item__galerie-item {
  width: 100%;
  aspect-ratio: 3 / 2;
  overflow: hidden;
  position: relative;
}

.projet-item__galerie-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
width: 100%;
  height: auto;
  will-change: transform;
  transform: translateY(-17%);
}

/* Sticky header when project is open */
.projet-item.is-open .projet-item__header {
  position: sticky;
  top: 80px;
  background: #fff;
  z-index: 10;
  border-bottom: 1px solid #000;
}

/* ===========================================
   À PROPOS
   =========================================== */
.apropos {
  background: #000;
  padding-top: 120px;
  padding-bottom: 120px;
}

.apropos__title-cell {
  border-bottom: 1px solid #fff;
  padding-bottom: 20px;
  margin-bottom: 40px;
}

.apropos__title {
  font-family: 'Grotta', sans-serif;
  font-size: clamp(14px, 2.8vw, 36px);
  line-height: 1.3;
  color: #fff;
}

.apropos__image {
  width: 320px;
  height: 320px;
  margin-top: 40px;
  margin-bottom: 40px;
  overflow: hidden;
}

.apropos__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.apropos__text {
  font-family: 'Grotta', sans-serif;
  font-size: clamp(14px, 2.8vw, 36px);
  line-height: 1.3;
  color: #fff;
}

.apropos__text p { margin-bottom: 1em; }

/* ===========================================
   CONTACT
   =========================================== */
.contact {
  background: #000;
  padding-top: 0;
  padding-bottom: 120px;
}

.contact__title-cell {
  border-bottom: 1px solid #fff;
  padding-bottom: 20px;
  margin-bottom: 40px;
}

.contact__title {
  font-family: 'Grotta', sans-serif;
  font-size: clamp(14px, 2.8vw, 36px);
  line-height: 1.3;
  color: #fff;
}

.contact__info {
  font-family: 'Grotta', sans-serif;
  font-size: clamp(14px, 2.8vw, 36px);
  line-height: 1.6;
  color: #fff;
  margin-top: 40px;
}

.contact__info a {
  position: relative;
  display: inline-block;
}

.contact__info a::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 100%;
  height: 1px;
  background: #fff;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

@media (hover: hover) { .contact__info a:hover::after { transform: scaleX(1); } }

.contact__links {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}

.contact__links-sep {
  opacity: 0.6;
}

/* ===========================================
   RESPONSIVE — mobile (max 768px)
   =========================================== */
@media (max-width: 768px) {
  .container { padding: 0 16px; }
  html { scroll-padding-top: 60px; }
  .header__inner { height: 60px; }
  .header__logo { font-size: 18px; }
  .header__lang-btn { font-size: 18px; }
  .header__lang-sep { font-size: 18px; }
  .header__right { gap: 20px; }
  .header__burger { width: 26px; height: 10px; }
  .header__burger-line { width: 26px; height: 2px; }
  .menu { top: 60px; }
  .menu__item { height: 80px; }
  .menu.is-open { max-height: 162px; }
  .menu__item-text { font-size: 18px; }
  .hero { padding-top: 32px; padding-bottom: 0; }
  .hero__line { font-size: clamp(22px, 7vw, 48px); }
  .projets { padding-top: 60px; padding-bottom: 40px; }
  .projets__title { font-size: 18px; padding-bottom: 16px; }
  .projet-item__name { font-size: clamp(24px, 7vw, 40px); }
  .projet-item__miniature { display: none; }
  .projet-item__close { width: 24px; height: 24px; }
  .projet-item__close::before,
  .projet-item__close::after { width: 24px; height: 2px; }
  .projet-item.is-open .projet-item__header { top: 60px; }
  .projet-item__fiche-inner { padding: 24px 0 48px; }
  .projet-item__description { font-size: 18px; line-height: 1.4; margin-bottom: 32px; }
  .projet-item__galerie-item { aspect-ratio: 4 / 3; }
  .apropos { padding-top: 80px; padding-bottom: 80px; }
  .apropos__title { font-size: 18px; }
  .apropos__title-cell { padding-bottom: 16px; margin-bottom: 32px; }
  .apropos__image { width: 160px; height: 160px; margin-top: 32px; margin-bottom: 32px; }
  .apropos__text { font-size: 18px; line-height: 1.4; }
  .contact { padding-bottom: 80px; }
  .contact__title { font-size: 18px; }
  .contact__title-cell { padding-bottom: 16px; margin-bottom: 32px; }
  .contact__info { font-size: 18px; line-height: 1.5; margin-top: 32px; }
}

@media (max-width: 380px) {
  .projet-item__name { font-size: 22px; }
}

/* ===========================================
   SELECTION
   =========================================== */
::selection { background: #000; color: #fff; }

/* ===========================================
   CUSTOM CURSOR — yellow halo (desktop only)
   =========================================== */
.cursor-halo {
  position: fixed;
  top: 0; left: 0;
  width: 240px; height: 240px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 0, 1) 0%, rgba(255, 255, 0, 0) 70%);
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
  opacity: 0;
}
.cursor-halo.is-visible { opacity: 1; }
.cursor-halo.is-hover { width: 360px; height: 360px; }
.hero, .apropos, .contact { cursor: none; }
.hero a, .apropos a, .contact a { cursor: none; }

@media (pointer: coarse) {
  .cursor-halo { display: none; }
  .hero, .apropos, .contact { cursor: auto; }
  .hero a, .apropos a, .contact a { cursor: auto; }
}

/* ===========================================
   SCROLL REVEAL
   =========================================== */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s cubic-bezier(0.25, 0.1, 0.25, 1),
              transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
}
.reveal.is-visible { opacity: 1; transform: translateY(0); }

/* ===========================================
   VIDEO & LOTTIE in galerie
   =========================================== */
.projet-item__galerie-item video.projet-item__galerie-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
height: 120%;
  object-fit: cover;
  will-change: transform;
  transform: translateY(-10%);
}

.projet-item__galerie-lottie {
  width: 100%;
  height: 100%;
}

/* Lottie items don't need parallax overflow */
.projet-item__galerie-item:has(lottie-player) {
  aspect-ratio: 3 / 2;
}
.projet-item__galerie-item:has(lottie-player) .projet-item__galerie-lottie {
  position: absolute;
  top: 0;
  left: 0;
}
</style>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
</head>
<body>
<div class="cursor-halo" id="cursorHalo"></div>

<!-- HEADER -->
<header class="header">
  <div class="container">
    <div class="header__inner">
      <a href="#" class="header__logo" id="logo">Xavier Perrillat</a>
      <div class="header__right">
        <div class="header__lang">
          <button class="header__lang-btn" data-lang="en">En</button>
          <span class="header__lang-sep">|</span>
          <button class="header__lang-btn active" data-lang="fr">Fr</button>
        </div>
        <div class="header__burger" id="menuBurger" role="button" aria-label="Menu">
          <span class="header__burger-line"></span>
          <span class="header__burger-line"></span>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- MENU -->
<nav class="menu" id="menu">
  <div class="container">
    <a class="menu__item" data-target="apropos"><span class="menu__item-text">À propos</span></a>
    <a class="menu__item" data-target="contact"><span class="menu__item-text">Contact</span></a>
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="container">
    <div class="hero__text reveal">
      {%- set animLineCount = 0 -%}
      {%- for line in hero.lines -%}
      {%- if line.animated -%}
        {%- set animLineCount = animLineCount + 1 -%}
      <span class="hero__line hero__line--animated" id="heroLine{{ loop.index }}">
        <span class="hero__slide-track">
          {%- for slide in line.slides %}
          <span class="hero__slide-item{% if loop.first %} is-visible{% else %} is-below{% endif %}">{{ slide }}</span>
          {%- endfor %}
        </span>
      </span>
      {%- else -%}
      <span class="hero__line">{{ line.text }}</span>
      {%- endif -%}
      {%- endfor %}
    </div>
    <div class="hero__placeholder"><span class="hero__placeholder-label">Showreel</span></div>
  </div>
</section>

<!-- PROJETS -->
<section class="projets" id="projets">
  <div class="container">
    <h2 class="projets__title reveal">Réalisations récentes</h2>
    {%- for projet in projets.items %}
    <article class="projet-item">
      <div class="projet-item__header">
        <span class="projet-item__name">{{ projet.name }}</span>
        <div class="projet-item__miniature">
          {%- if projet.miniature %}<img src="{{ projet.miniature }}" alt="" loading="lazy">{% endif -%}
        </div>
        <button class="projet-item__close" aria-label="Fermer"></button>
      </div>
      <div class="projet-item__fiche">
        <div class="projet-item__fiche-inner">
          <p class="projet-item__description">{{ projet.description }}</p>
          <div class="projet-item__galerie">
            {%- for media in projet.medias %}
            <div class="projet-item__galerie-item">
              {%- if media.type == "video" %}
              <video class="projet-item__galerie-img" src="{{ media.file }}" autoplay muted loop playsinline loading="lazy"></video>
              {%- elif media.type == "lottie" %}
              <lottie-player class="projet-item__galerie-lottie" src="{{ media.file }}" background="transparent" speed="1" loop autoplay></lottie-player>
              {%- else %}
              <img class="projet-item__galerie-img" src="{{ media.file }}" alt="" loading="lazy">
              {%- endif %}
            </div>
            {%- endfor %}
          </div>
        </div>
      </div>
    </article>
    {%- endfor %}
  </div>
</section>

<!-- À PROPOS -->
<section class="apropos" id="apropos">
  <div class="container">
    <div class="apropos__title-cell reveal"><h2 class="apropos__title">À propos</h2></div>
    <div class="apropos__image reveal">
      {%- if apropos.image %}<img src="{{ apropos.image }}" alt="Xavier Perrillat">{% endif -%}
    </div>
    <div class="apropos__text reveal">
      {%- for p in apropos.paragraphs %}
      <p>{{ p }}</p>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="contact" id="contact">
  <div class="container">
    <div class="contact__title-cell reveal"><h2 class="contact__title">Contact</h2></div>
    <div class="contact__info reveal">
      <p>M › <a href="mailto:{{ contact.email }}">{{ contact.email }}</a></p>
      <p>T › <a href="tel:{{ contact.phone_link }}">{{ contact.phone }}</a></p>
      <div class="contact__links">
        <a href="{{ contact.instagram }}">Insta</a>
        <span class="contact__links-sep">|</span>
        <a href="{{ contact.linkedin }}">Linkedin</a>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  'use strict';
  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  /* ---- MENU ---- */
  const burger = document.getElementById('menuBurger');
  const menu = document.getElementById('menu');
  let menuOpen = false;

  burger.addEventListener('click', () => {
    menuOpen = !menuOpen;
    menu.classList.toggle('is-open', menuOpen);
    burger.classList.toggle('is-cross', menuOpen);
  });

  function closeMenu() {
    menuOpen = false;
    menu.classList.remove('is-open');
    burger.classList.remove('is-cross');
  }

  document.querySelectorAll('.menu__item').forEach(item => {
    item.addEventListener('click', () => {
      const target = document.getElementById(item.dataset.target);
      closeMenu();
      if (target) setTimeout(() => target.scrollIntoView({ behavior: 'smooth' }), 400);
    });
  });

  document.getElementById('logo').addEventListener('click', (e) => {
    e.preventDefault();
    closeMenu();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  /* ---- LANG ---- */
  document.querySelectorAll('.header__lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.header__lang-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  /* ---- HERO ANIMATION ---- */
  function initHeroSlider(lineId) {
    const line = document.getElementById(lineId);
    if (!line) return;
    const items = Array.from(line.querySelectorAll('.hero__slide-item'));
    if (items.length < 2) return;
    let current = 0;
    let animating = false;

    function randomDelay() { return 1200 + Math.random() * 1300; }

    function next() {
      if (animating) return;
      animating = true;
      const cur = items[current];
      const nextIdx = (current + 1) % items.length;
      const nxt = items[nextIdx];

      nxt.classList.remove('sliding', 'is-below', 'is-visible');
      nxt.style.transform = 'translateY(115%)';
      void nxt.offsetHeight;

      cur.classList.add('sliding');
      nxt.classList.add('sliding');
      cur.style.transform = 'translateY(-115%)';
      nxt.style.transform = 'translateY(0%)';
      current = nextIdx;

      setTimeout(() => {
        cur.classList.remove('sliding', 'is-visible');
        cur.classList.add('is-below');
        cur.style.transform = '';
        nxt.classList.remove('sliding', 'is-below');
        nxt.classList.add('is-visible');
        nxt.style.transform = '';
        animating = false;
        setTimeout(next, randomDelay());
      }, 650);
    }

    setTimeout(next, randomDelay());
  }

  // Auto-detect animated lines
  document.querySelectorAll('.hero__line--animated').forEach(el => {
    initHeroSlider(el.id);
  });

  /* ---- ACCORDION ---- */
  const projetItems = document.querySelectorAll('.projet-item');

  function openProjet(item) {
    const fiche = item.querySelector('.projet-item__fiche');
    const inner = fiche.querySelector('.projet-item__fiche-inner');

    fiche.style.height = 'auto';
    fiche.style.visibility = 'hidden';
    fiche.style.position = 'absolute';
    const targetH = inner.offsetHeight;
    fiche.style.height = '0px';
    fiche.style.visibility = '';
    fiche.style.position = '';

    item.classList.add('is-open');
    fiche.style.transition = 'height 0.5s cubic-bezier(0.4, 0, 0.2, 1)';

    requestAnimationFrame(() => {
      fiche.style.height = targetH + 'px';
    });

    function done() {
      fiche.style.height = 'auto';
      fiche.style.transition = '';
      fiche.removeEventListener('transitionend', done);
    }
    fiche.addEventListener('transitionend', done);
  }

  function closeProjet(item) {
    const fiche = item.querySelector('.projet-item__fiche');
    const h = fiche.scrollHeight;
    fiche.style.height = h + 'px';
    fiche.style.transition = 'height 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
    item.classList.remove('is-open');

    requestAnimationFrame(() => {
      fiche.style.height = '0px';
    });

    function done() {
      fiche.style.transition = '';
      fiche.removeEventListener('transitionend', done);
    }
    fiche.addEventListener('transitionend', done);
  }

  function instantCloseProjet(item) {
    const fiche = item.querySelector('.projet-item__fiche');
    const inner = fiche.querySelector('.projet-item__fiche-inner');
    inner.style.transition = 'none';
    item.classList.remove('is-open');
    fiche.style.height = '0px';
    requestAnimationFrame(() => { inner.style.transition = ''; });
  }

  const projetArray = Array.from(projetItems);

  projetItems.forEach(item => {
    const headerEl = item.querySelector('.projet-item__header');

    headerEl.addEventListener('click', () => {
      if (item.classList.contains('is-open')) {
        const stickyH = window.innerWidth <= 768 ? 60 : 80;
        closeProjet(item);
        item.scrollIntoView({ behavior: 'instant', block: 'start' });
        window.scrollBy(0, -stickyH);
        return;
      }

      const openItem = document.querySelector('.projet-item.is-open');

      if (openItem && openItem !== item) {
        const openIndex = projetArray.indexOf(openItem);
        const clickIndex = projetArray.indexOf(item);

        if (openIndex < clickIndex) {
          const topBefore = item.getBoundingClientRect().top;
          instantCloseProjet(openItem);
          const topAfter = item.getBoundingClientRect().top;
          const drift = topAfter - topBefore;
          if (Math.abs(drift) > 1) {
            window.scrollBy(0, drift);
          }
          openProjet(item);
        } else {
          instantCloseProjet(openItem);
          openProjet(item);
        }
      } else {
        openProjet(item);
      }
    });
  });

  /* ---- MINIATURE ---- */
  projetItems.forEach(item => {
    const headerEl = item.querySelector('.projet-item__header');
    const mini = item.querySelector('.projet-item__miniature');
    headerEl.addEventListener('mousemove', (e) => {
      if (item.classList.contains('is-open')) return;
      const rect = headerEl.getBoundingClientRect();
      const mw = mini.offsetWidth;
      mini.style.left = Math.max(0, Math.min(e.clientX - rect.left - mw / 2, rect.width - mw)) + 'px';
    });
  });

  /* ---- PARALLAX ---- */
const parallaxCenter = isMobile ? -10 : -15;
  const parallaxFactor = isMobile ? 20 : 35;
  (function parallax() {
    const vh = window.innerHeight;
    document.querySelectorAll('img.projet-item__galerie-img').forEach(img => {
      const r = img.parentElement.getBoundingClientRect();
      if (r.top < vh && r.bottom > 0) {
        const p = Math.max(0, Math.min(1, (vh - r.top) / (vh + r.height)));
        img.style.transform = 'translateY(' + (parallaxCenter + (0.5 - p) * parallaxFactor) + '%)';
      }
    });
    requestAnimationFrame(parallax);
  })();

  /* ---- SCROLL REVEAL ---- */
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  /* ---- CUSTOM CURSOR HALO ---- */
  const halo = document.getElementById('cursorHalo');
  let mouseX = -100, mouseY = -100;
  let haloX = -100, haloY = -100;
  const ease = 0.15;

  document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

  (function moveHalo() {
    haloX += (mouseX - haloX) * ease;
    haloY += (mouseY - haloY) * ease;
    halo.style.left = haloX + 'px';
    halo.style.top = haloY + 'px';
    requestAnimationFrame(moveHalo);
  })();

  const haloSections = document.querySelectorAll('.hero, .apropos, .contact');
  haloSections.forEach(s => {
    s.addEventListener('mouseenter', () => halo.classList.add('is-visible'));
    s.addEventListener('mouseleave', () => halo.classList.remove('is-visible'));
  });

  const haloClickables = document.querySelectorAll('.hero a, .apropos a, .contact a');
  haloClickables.forEach(el => {
    el.addEventListener('mouseenter', () => halo.classList.add('is-hover'));
    el.addEventListener('mouseleave', () => halo.classList.remove('is-hover'));
  });

})();
</script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) { window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; }); }
    });
  }
</script>
</body>
</html>
